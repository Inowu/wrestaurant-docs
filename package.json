{
  "name": "wrestaurant-docs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "gen:versions": "node scripts/gen-api-versions.mjs",
    "dev": "pnpm gen:versions && zudoku dev",
    "build": "pnpm gen:versions && zudoku build && mkdir -p dist/apis && cp apis/openapi*.json dist/apis/",
    "preview": "wrangler dev",
    "lint": "eslint",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zudoku": "0.80.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^8",
    "typescript": "^5",
    "wrangler": "^4.94.0"
  }
}
