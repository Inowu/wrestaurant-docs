{
  "openapi": "3.0.1",
  "info": {
    "title": "W Restaurant API",
    "description": "Gateway multi-tenant para Soft Restaurant. Registra tus sucursales y consulta sus datos en tiempo real.",
    "version": "v0"
  },
  "paths": {
    "/api/v0/productos/{licenseKey}": {
      "get": {
        "tags": [
          "Endpoints"
        ],
        "summary": "Listar productos",
        "description": "Devuelve el catálogo de productos de una sucursal, con paginación y filtros opcionales por grupo, clasificación y visibilidad en menú.",
        "parameters": [
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "API key secreta de tu cuenta. Se envía en cada solicitud.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "ejemplo": {
                "value": "TU_API_KEY"
              }
            }
          },
          {
            "name": "licenseKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 100
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "idGrupo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clasificacion",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "visibleMenu",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductsQueryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/estaciones/{licenseKey}": {
      "get": {
        "tags": [
          "Endpoints"
        ],
        "summary": "Listar estaciones",
        "description": "Devuelve las estaciones (mesas, áreas, terminales) configuradas en una sucursal, con paginación y búsqueda opcional.",
        "parameters": [
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "API key secreta de tu cuenta. Se envía en cada solicitud.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "ejemplo": {
                "value": "TU_API_KEY"
              }
            }
          },
          {
            "name": "licenseKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 100
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StationsQueryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/temp_ordenes/{licenseKey}": {
      "post": {
        "tags": [
          "Endpoints"
        ],
        "summary": "Crear una orden (nueva cuenta)",
        "description": "Crea una nueva cuenta y retorna el id.",
        "parameters": [
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "API key secreta de tu cuenta. Se envía en cada solicitud.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "ejemplo": {
                "value": "TU_API_KEY"
              }
            }
          },
          {
            "name": "licenseKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Endpoints"
        ],
        "summary": "Listar órdenes temporales",
        "description": "Devuelve las órdenes abiertas (tempcheques) del Punto de Venta de una sucursal, con filtro opcional por folio, número de cheque o total.",
        "parameters": [
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "API key secreta de tu cuenta. Se envía en cada solicitud.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "ejemplo": {
                "value": "TU_API_KEY"
              }
            }
          },
          {
            "name": "licenseKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
