    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Token JWT Bearer. Se obtiene desde POST /api/v0/auth/login. Usado por los endpoints de administración.",
        "name": "Authorization",
        "in": "header"
      },
      "ApiKey": {
        "type": "apiKey",
        "description": "API key secreta. Se obtiene desde POST /api/v0/apikeys. Usada por los endpoints públicos de consulta (productos, estaciones).",
        "name": "X-Api-Key",
        "in": "header"
      },
      "LicenseKey": {
        "type": "apiKey",
        "description": "License key del worker (16 caracteres). Usada por los endpoints de auto-gestión del agente local (estadísticas, instalación).",
        "name": "X-License-Key",
        "in": "header"
      }
    }
